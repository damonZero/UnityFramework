# JetBrains Rider workspace
.idea/

# WorkBuddy agent memory (local only)
.workbuddy/

# Unity Editor local user settings / layouts
UserSettings/

# Unity generated (regenerated on open, never commit)
Library/
Temp/
obj/
Logs/
Bundles/

# Build artifacts (large files, generated per build)
/Build/
/BuildBackup/
/HybridCLRData/

# HybridCLR generated DLL bytes — P4 YooAsset output (regenerated every build)
Assets/GameRes/HotUpdate/AotMetadata/*.bytes
Assets/GameRes/HotUpdate/Dlls/*.bytes

# YooAsset StreamingAssets rawfiles — P4 build output (regenerated every build)
Assets/StreamingAssets/yoo/

# IDE generated project files (regenerated by Unity)
*.csproj
*.sln

# Test results (regenerated every test run)
TestResults.xml
